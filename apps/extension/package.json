{
  "name": "@pinn/extension",
  "description": "Browser extension for capturing fragmented knowledge into Pinn",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "postinstall": "wxt prepare",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox"
  },
  "dependencies": {
    "@pinn/pages": "workspace:*",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
